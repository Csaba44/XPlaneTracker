####################
# APP
####################
APP_NAME=Xtracker
APP_ENV=production
APP_DEBUG=false
APP_URL=https://csabolanta.hu

# Make a key on local machine
APP_KEY=

APP_LOCALE=en
APP_FALLBACK_LOCALE=en

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=warning

####################
# DATABASE
####################
DB_CONNECTION=mysql
DB_HOST=mysql
DB_DATABASE=xtracker
DB_USERNAME=appuser
DB_PASSWORD=USER_PASSWORD

# MYSQL INIT
MYSQL_ROOT_PASSWORD=ROOT_PASSWORD

####################
# SESSION
####################
SESSION_DRIVER=cookie
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=csabolanta.hu

FILESYSTEM_DISK=local

CACHE_STORE=redis
QUEUE_CONNECTION=redis

SANCTUM_STATEFUL_DOMAINS=csabolanta.hu,localhost,localhost,nginx


REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

REVERB_APP_ID=xtracker-live
REVERB_APP_KEY=xtracker-key
REVERB_APP_SECRET=xtracker-secret
REVERB_HOST="localhost"
REVERB_PORT=8080
REVERB_SCHEME=http

VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"