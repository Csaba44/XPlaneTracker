####################
# APP
####################
APP_NAME=Xtracker
APP_ENV=production
APP_DEBUG=false
APP_URL=https://csabolanta.hu

# Make a key on local machine
APP_KEY=

APP_LOCALE=en
APP_FALLBACK_LOCALE=en

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=warning

####################
# DATABASE
####################
DB_CONNECTION=mysql
DB_HOST=mysql
DB_DATABASE=xtracker
DB_USERNAME=appuser
DB_PASSWORD=USER_PASSWORD

# MYSQL INIT
MYSQL_ROOT_PASSWORD=ROOT_PASSWORD

####################
# SESSION
####################
SESSION_DRIVER=cookie
SESSION_LIFETIME=10080
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=csabolanta.hu

FILESYSTEM_DISK=local

CACHE_STORE=database

SANCTUM_STATEFUL_DOMAINS=csabolanta.hu,localhost,localhost,nginx


JETPHOTOS_WORKER_URL=http://jetphotos-worker:8787